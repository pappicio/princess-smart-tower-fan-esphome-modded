@EndOfDesignText@
#Region  Project Attributes 
	#ApplicationLabel: Princess Fan Commander
	#VersionCode: 1
	#VersionName: 
	'SupportedOrientations possible values: unspecified, landscape or portrait.
	#SupportedOrientations: unspecified
	#CanInstallToExternalStorage: False
#End Region

#Region  Activity Attributes 
	#FullScreen: False
	#IncludeTitle: True
#End Region
Sub Process_Globals
	Private xui As XUI
	Private currentSpeed As Int = 1
	Private swingOn As Boolean = False
	Private modeBits As Int = 0
	Private timerSteps As Int = 0
	Private serveAggiornamento  As Boolean=False
	Private polltimer As Timer 
	Private timerDebounce As Timer
	Private kvs As KeyValueStore
	
	Private ventilatori As List
	
	
	Private modeStr As String =""
	Private minutiReali As Int = 0
	Private opzione As String = ""
	Private statoOn As Boolean = False
	Private abilita As Boolean=False
	

End Sub

Sub Globals
	Private btnOn As Button
	Private btnOff As Button
	Private btnSpeed1 As Button
	Private btnSpeed2 As Button
	Private btnSpeed3 As Button
	Private btnSwingOn As Button
	Private btnSwingOff As Button
	Private btnNormal As Button
	Private btnNatural As Button
	Private btnSleep As Button
	Private EditText1 As EditText
	Private btnBeepOn As Button
	Private btnBeepOff As Button
	Private Label2 As Label
	Private sbTimer As SeekBar
	Private lblTimerValore As Label
	Private Buttonok As Button
	Private Spinner1 As Spinner


	Private Label3 As Label
End Sub

Sub attiva_pannello
	Label3.Enabled=True
	Label3.BringToFront
	Label3.Visible=True
	Sleep(0)
End Sub

Sub LeggiStatoIniziale
    
	Dim job As HttpJob
	job.Initialize("stato_iniziale", Me)
	job.GetRequest.Timeout = 3000   ' <-- PRIMA di Download
	job.Download("http://" & EditText1.Text.Trim & "/fan/Ventilatore")
    
	Wait For (job) JobDone(job As HttpJob)
	If job.Success Then
		Dim jsonStr As String = job.GetString
		Log("Stato ricevuto: " & jsonStr)
		Dim parser As JSONParser
		parser.Initialize(jsonStr)
		Dim root As Map = parser.NextObject
		statoOn = root.Get("value")
		Dim speedLevel As Int = root.Get("speed_level")
		Dim oscillation As Boolean = root.Get("oscillation")
		currentSpeed = speedLevel
		swingOn = oscillation
		abilita = True
		Log("Sincronizzato: on=" & statoOn & " speed=" & currentSpeed & " swing=" & swingOn)
        
		'AggiornaUISelezione(statoOn)
	Else
		If job.ErrorMessage.ToLowerCase.Contains("timeout") Then
			Log("Timeout: dispositivo non raggiungibile entro 5s")
		Else
			Log("Errore lettura stato: " & job.ErrorMessage)
		End If
		abilita = False
	End If
    
	job.Release
	Sleep(0)
    
End Sub

Sub resettacolori (enabled As Boolean)
	attiva_pannello
	Sleep(0)
	Dim i As Int
	For i = 0 To Activity.NumberOfViews - 1
		Dim v As View = Activity.GetView(i)
			If enabled=False And v<>Label3 Then
				v.Enabled = False
			Else
				v.Enabled = True
			End If
		
	''	'If v Is Button Then
	''		'Dim b As Button = v
	''		'b.Color = Colors.LightGray   ' colore a tua scelta
	''	'End If
	Next
	Spinner1.Enabled=True
	EditText1.Enabled=True
	Buttonok.Enabled=True
	Sleep(0)
End Sub



Sub AggiornaUISelezione
	If abilita=True Then
		If statoOn Then
			btnOn.Color=Colors.Gray
			btnOff.Color=Colors.lightGray
		Else
			btnOff.Color=Colors.Gray
			btnOn.Color=Colors.lightGray
		End If

		If currentSpeed=1 Then
			btnSpeed1.Color=Colors.Gray
			btnSpeed2.Color=Colors.lightGray
			btnSpeed3.Color=Colors.lightGray
		else if currentSpeed=2 Then
			btnSpeed2.Color=Colors.Gray
			btnSpeed1.Color=Colors.lightGray
			btnSpeed3.Color=Colors.lightGray
		Else
			btnSpeed3.Color=Colors.Gray
			btnSpeed1.Color=Colors.lightGray
			btnSpeed2.Color=Colors.lightGray
		End If
	
		If swingOn Then
			btnSwingOn.color=Colors.Gray
			btnSwingOff.color=Colors.lightGray
		Else
			btnSwingOff.color=Colors.Gray
			btnSwingOn.color=Colors.lightGray
		End If
	
		If opzione = "Beep Breve" Then
			btnBeepOn.Color=Colors.Gray
			btnBeepOff.Color=Colors.lightGray
		Else
			btnBeepOff.Color=Colors.Gray
			btnBeepOn.Color=Colors.lightGray
		End If
	
		If modeStr = "natural" Then
			modeBits = 8
			btnNatural.Color=Colors.gray
			btnNormal.Color=Colors.lightgray
			btnSleep.Color=Colors.lightgray
		Else If modeStr = "sleep" Then
			modeBits = 16
			btnSleep.Color=Colors.gray
			btnNormal.Color=Colors.lightgray
			btnNatural.Color=Colors.lightgray
		Else
			modeBits = 0
			btnNormal.Color=Colors.gray
			btnNatural.Color=Colors.lightgray
			btnSleep.Color=Colors.lightgray
		End If
		resettacolori(abilita)
		abilita=False
	
	Else
 		
		btnOn.Color=Colors.lightGray
		btnOff.Color=Colors.lightGray

		btnSpeed1.Color=Colors.lightGray
		btnSpeed2.Color=Colors.lightGray
		btnSpeed3.Color=Colors.lightGray
		
		btnSwingOn.color=Colors.lightGray
		btnSwingOff.color=Colors.lightGray
	
		btnBeepOn.Color=Colors.lightGray
		btnBeepOff.Color=Colors.lightGray

		modeBits = 0
		btnNormal.Color=Colors.lightGray
		btnNatural.Color=Colors.lightgray
		btnSleep.Color=Colors.lightgray
		resettacolori(False)
		abilita=False
		ToastMessageShow("Impossibile connettersi con il Ventilatore selezionato!",True)
	End If
	
	Label3.Visible=False
	Sleep(0)
	
End Sub


Sub Activity_Create(FirstTime As Boolean)
	
	Activity.LoadLayout("Layout")
	
	kvs.Initialize(File.DirInternal, "settings.dat")
	ventilatori.Initialize
	ventilatori.Clear
	Spinner1.Clear
	
	For x=0 To 9
		If kvs.ContainsKey("ventilatore" & x) Then
			ventilatori.Add(kvs.Get("ventilatore" & x))
			Spinner1.Add((kvs.Get("ventilatore" & x)))
		End If
	Next
	
	If kvs.ContainsKey("ip_ventilatore") Then
		EditText1.Text = kvs.Get("ip_ventilatore")
	Else
		EditText1.Text = "192.168.1.1"
	End If
	
	For x=0 To ventilatori.Size-1
		Dim s As String=ventilatori.Get(x)
		If s=EditText1.Text Then 
			Spinner1.SelectedIndex=x
		End If
	Next
 
	timerDebounce.Initialize("timerDebounce", 1000)
	polltimer.Initialize("pollTimer", 1000)
	polltimer.Enabled = True
	
End Sub
 

Sub Activity_Resume
	applica_modifiche(True)
End Sub

Sub sbTimer_ValueChanged (Value As Int, UserChanged As Boolean)
	Dim minuti As Int = Value * 10
	Dim ore As Int = minuti / 60
	Dim minResto As Int = minuti Mod 60

	If minuti = 0 Then
		lblTimerValore.Text = "Timer: Off"
	Else If ore = 0 Then
		lblTimerValore.Text = minResto & " min"
	Else If minResto = 0 Then
		lblTimerValore.Text = ore & " " & IIf(ore = 1, "ora", "ore")
	Else
		lblTimerValore.Text = ore & " " & IIf(ore = 1, "ora e " , "ore e ") & minResto & " min"
	End If
	
	Dim minuti As Int = sbTimer.Value * 10
	timerSteps = minuti / 2
	' Solo se il cambio è dovuto al dito dell'utente (non a un aggiornamento programmatico)
	If UserChanged Then
		timerDebounce.Enabled = False
		timerDebounce.Enabled = True   ' riavvia il countdown da zero ad ogni movimento
	End If
End Sub

Sub timerDebounce_Tick
	timerDebounce.Enabled = False   ' scatta una sola volta
	InviaStatoCorrente
End Sub

Sub LeggiTimer
	Dim job As HttpJob
	job.Initialize("stato_timer", Me)
	job.GetRequest.Timeout = 3000
	job.Download("http://" & EditText1.Text.Trim & "/number/Ventilatore Timer (minuti)")

	Wait For (job) JobDone(job As HttpJob)

	If job.Success Then
		Dim parser As JSONParser
		parser.Initialize(job.GetString)
		Dim root As Map = parser.NextObject
		 minutiReali  = root.Get("value")

		sbTimer.Value = minutiReali / 10
		sbTimer_ValueChanged(sbTimer.Value, False)

		Log("Timer sincronizzato: " & minutiReali & " min")
	Else
		Log("Errore lettura timer: " & job.ErrorMessage)
	End If
	job.Release
End Sub

Sub pollTimer_Tick
	 
	If serveAggiornamento Then
		serveAggiornamento = False
	 
		LeggiStatoIniziale
		Sleep(100)
		LeggiBeepMode
		Sleep(100)
		LeggiModalita
		Sleep(100)
		LeggiTimer
		Sleep(100)
		AggiornaUISelezione
		polltimer.Enabled = False
		Sleep(10)
		
	End If
End Sub


Sub HexPad2(valore As Int) As String
	Dim h As String = Bit.ToHexString(valore)
	Do While h.Length < 2
		h = "0" & h
	Loop
	Return h
End Sub

Sub InviaComandoRaw(comandoHex As String, infoExtra As String)
	Dim job As HttpJob
	job.Initialize("", Me)
	job.GetRequest.Timeout = 3000
	Dim url As String = "http://" & EditText1.Text.Trim & "/text/Ventilatore Comando Raw/set?value=" & comandoHex
	job.PostString(url, "")

	job.GetRequest.SetHeader("Content-Length", "0")

	Wait For (job) JobDone(job As HttpJob)
	If job.Success Then
		Log("Inviato: " & comandoHex)
		Dim msg As String = "Comando: " & comandoHex
		If infoExtra <> "" Then
			msg = msg & " (" & infoExtra & ")"
		End If
		ToastMessageShow(msg, False)
		attiva_pannello
		serveAggiornamento = True
		polltimer.Enabled=False
		polltimer.Enabled=True
	Else
		Log("Errore: " & job.ErrorMessage)
		ToastMessageShow("Errore: " & job.ErrorMessage, True)
		polltimer.Enabled=False
		serveAggiornamento = False
	End If
	job.Release
End Sub



		
