	InviaStatoCorrente
End Sub

Sub applica_modifiche(add As Boolean)
	
	statoOn=False
	currentSpeed=0
	swingOn=False
	opzione=""
	modeStr=""
	
	If add Then
		If IsValidIP(EditText1.text.trim) Then
			Log("L'indirizzo IP è valido.")
			resettacolori(False)
			attiva_pannello
			kvs.Put("ip_ventilatore", EditText1.Text.Trim)
			Dim b As Boolean=False
			Dim x As Int=0
			For x=0 To ventilatori.Size-1
				Dim s As String=ventilatori.Get(x)
				If s.Trim.ToLowerCase=EditText1.Text.Trim.ToLowerCase Then
					b=True
					Exit
				End If
			Next
			If b=False Then
				kvs.Put("ventilatore" & x, EditText1.Text.Trim)
				ventilatori.Add(EditText1.Text.Trim)
				Spinner1.Add(EditText1.Text.Trim)
				Spinner1.SelectedIndex=x
				ToastMessageShow("IP salvato: " & EditText1.Text.Trim, False)
			End If
			EditText1.Visible=False
			Spinner1.Visible=True
			Spinner1.SelectedIndex=x
			kvs.Put("ip_ventilatore" , EditText1.Text.Trim)
		
		 
			attiva_pannello
			serveAggiornamento = True
			polltimer.Enabled=False
			polltimer.Enabled=True
		Else
			MsgboxAsync("Controllare IP inserito: " & EditText1.Text & " non Valido", "IP NON VALIDO")
			Wait For Msgbox_Result (Result As Int)
		End If
		
	Else
		kvs.Remove( Spinner1.SelectedItem)
		ventilatori.RemoveAt(Spinner1.SelectedIndex)
		Spinner1.RemoveAt(Spinner1.SelectedIndex)
		Try
			Spinner1.SelectedIndex=0
			EditText1.Text=Spinner1.SelectedItem
			kvs.DeleteAll
			For x=0 To ventilatori.Size-1
				kvs.Put("ventilatore" & x, ventilatori.Get(x))
			Next
			kvs.Put("ip_ventilatore" , EditText1.Text.Trim)
			Buttonok_Click
		Catch
			Log(LastException)
		End Try
	End If

End Sub
Private Sub Buttonok_Click
	If EditText1.Visible Then
		applica_modifiche(True)
	End If

	
End Sub

Private Sub Spinner1_ItemClick (Position As Int, Value As Object)
	'''If EditText1.Text.Trim.ToLowerCase<>Spinner1.SelectedItem.Trim.ToLowerCase Then 
		EditText1.Text=Spinner1.SelectedItem
		applica_modifiche(True)
	'''End If
End Sub

Private Sub Buttonok_LongClick
	If Spinner1.Visible=True Then
		EditText1.Text=Spinner1.SelectedItem
		EditText1.Visible=True
		Spinner1.Visible=False
	Else
		Msgbox2Async("Eliminare l' IP: " & EditText1.Text,"Elimina IP", "SI","NO", "",Null, False)
		Wait For Msgbox_Result (Result As Int)
		If Result = DialogResponse.POSITIVE Then
			ToastMessageShow("IP eliminato: " & EditText1.Text.Trim, False)
  			applica_modifiche(False)
		Else
			EditText1.Text=Spinner1.SelectedItem
			EditText1.Visible=False
			Spinner1.Visible=True
		End If
	End If
End Sub

Sub IsValidIP(IPAddress As String) As Boolean
	Dim pattern As String = "^(([01]?\d\d?|2[0-4]\d|25[0-5])\.){3}([01]?\d\d?|2[0-4]\d|25[0-5])$"
	Return Regex.IsMatch(pattern, IPAddress)
End Sub